{
  "name": "CheeseHacks",
  "displayName": "Cheese hacks",
  "version": "0.0.1",
  "description": "A water usage tracker for AI tools",
  "author": "kantankah@wisc.edu",
  "scripts": {
    "dev": "plasmo dev --target=firefox-mv2",
    "build": "plasmo build --target=firefox-mv2",
    "package": "plasmo package --target=firefox-mv2"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "icons": {
      "128": "../assets/icon.png"
    },
    "browser_action": {
      "default_title": "Water Tracker"
    },
    "sidebar_action": {
      "default_panel": "sidepanel.html",
      "default_title": "Water Tracker"
    },
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://chatgpt.com/*",
      "https://claude.ai/*"
    ]
  }
}
